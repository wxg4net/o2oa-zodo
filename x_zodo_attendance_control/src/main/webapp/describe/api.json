        },
        {
          "name": "setDeviceCommunicationPassword",
          "uri": "jaxrs/attendance/device/v1/{ip}/communication/{password}",
          "method": "GET"
        }
      ]
    },
    {
      "name": "DeviceV2Action",
      "methods": [
        {
          "name": "getList",
          "uri": "jaxrs/attendance/device/v2/list",
          "method": "GET"
        },
        {
          "name": "getListOnline",
          "uri": "jaxrs/attendance/device/v2/list/online",
          "method": "GET"
        },
        {
          "name": "setDeviceTime",
