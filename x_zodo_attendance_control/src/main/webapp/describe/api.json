        },
        {
          "name": "commonScriptFlush",
          "uri": "jaxrs/cache/commonscript/flush",
          "method": "GET"
        },
        {
          "name": "receive",
          "uri": "jaxrs/cache",
          "method": "POST",
          "enctype": "application/json"
        }
      ]
    },
    {
      "name": "DeviceV1Action",
      "methods": [
        {
          "name": "updateDeviceTime",
          "uri": "jaxrs/attendance/device/v1/{ip}/time/{time}",
