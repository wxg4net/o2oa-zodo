          "uri": "jaxrs/attendance/device/v2/door/{host}/status/{status}",
          "method": "GET"
        },
        {
          "name": "getDeviceSetting",
          "uri": "jaxrs/attendance/device/v2/setting/{host}",
          "method": "GET"
